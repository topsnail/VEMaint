{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./frontend/src/*"],
      "antd": ["./frontend/src/lib/ui/antd-bridge.tsx"],
      "@ant-design/icons": ["./frontend/src/lib/ui/icons-bridge.tsx"]
    },
    "types": ["@cloudflare/workers-types"]
  },
  "include": [
    "frontend/src/**/*.ts",
    "frontend/src/**/*.tsx",
    "functions/**/*.ts",
    "env.d.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
