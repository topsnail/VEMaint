{
  "name": "vemaint",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --host --port 4173 --strictPort",
    "pages:dev": "npm run build && wrangler pages dev dist --compatibility-date=2024-10-22",
    "check:local": "npx tsc --noEmit && npm run build",
    "db:init:local": "wrangler d1 execute vemaint --local --file=./drizzle/0000_init.sql",
    "db:init:remote": "wrangler d1 execute vemaint --remote --file=./drizzle/0000_init.sql",
    "db:migrate:local": "wrangler d1 execute vemaint --local --file=./drizzle/0001_maintenance_target_type_other.sql",
    "db:migrate:remote": "wrangler d1 execute vemaint --remote --file=./drizzle/0001_maintenance_target_type_other.sql",
    "db:seed:local": "wrangler d1 execute vemaint --local --file=./drizzle/seed.sql",
    "db:seed:remote": "wrangler d1 execute vemaint --remote --file=./drizzle/seed.sql",
    "kv:seed:local": "wrangler kv key put --local --binding=KV sys:config:v1 --path=./drizzle/dev-system-config.json",
    "r2:seed:local": "node ./scripts/seed-r2-local.mjs",
    "dev:reset-data:local": "npm run db:init:local && npm run db:migrate:local && npm run db:seed:local && npm run kv:seed:local && npm run r2:seed:local"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.99.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.20",
    "gsap": "^3.14.2",
    "hono": "^4.12.14",
    "i18next": "^25.3.4",
    "jose": "^5.9.6",
    "lucide-react": "^1.8.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.72.1",
    "react-i18next": "^15.7.3",
    "react-router-dom": "^6.30.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^6.4.2",
    "wrangler": "^4.65.0"
  },
  "overrides": {
    "esbuild": "^0.27.3"
  }
}
