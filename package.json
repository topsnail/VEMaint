{
  "name": "vemaint",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --host --port 4173",
    "pages:dev": "npm run build && wrangler pages dev dist --compatibility-date=2024-10-22",
    "db:migrate:local": "wrangler d1 migrations apply vemaint --local",
    "db:migrate:remote": "wrangler d1 migrations apply vemaint --remote",
    "db:seed:local": "wrangler d1 execute vemaint --local --file=./drizzle/seed.sql",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "antd": "^5.26.6",
    "hono": "^4.5.0",
    "jose": "^5.9.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "drizzle-kit": "^0.28.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^6.4.2",
    "wrangler": "^4.65.0"
  },
  "overrides": {
    "esbuild": "^0.27.3"
  }
}
