{
  "name": "vemaint",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "set NEXT_DISABLE_TRACE=1&& next dev -p 3000",
    "test": "npm run test:local",
    "test:local": "npm run db:migrate:local && npm run db:seed:local && npm run dev",
    "build": "next build",
    "start": "next start",
    "lint": "npm run lint:layout && next lint",
    "lint:layout": "node scripts/check-layout-widths.mjs",
    "pages:build": "npx @cloudflare/next-on-pages && node scripts/copy-pages-config.mjs",
    "pages:dev": "npm run pages:build && wrangler pages dev .vercel/output/static --compatibility-date=2024-10-22",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply vehicle-maintenance-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply vehicle-maintenance-db --remote",
    "db:seed:local": "wrangler d1 execute vehicle-maintenance-db --local --file=./drizzle/seed.sql",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-slot": "^1.1.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.36.4",
    "lucide-react": "^0.460.0",
    "next": "15.5.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.5",
    "@cloudflare/workers-types": "^4.20241127.0",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.28.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "15.5.2",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "wrangler": "^3.91.0"
  }
}
